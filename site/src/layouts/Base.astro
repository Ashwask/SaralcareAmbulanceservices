---
interface Props {
  title?: string;
  description?: string;
  hideHero?: boolean;
}
const {
  title = "Saralcare Ambulances — find and call an ambulance in Bangalore",
  description = "Find and call an ambulance in Bangalore. Government 108, private, charitable. Free, open, no ads, no commission. Works offline.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#b91c1c" />
    <meta name="robots" content="index,follow" />
    <link rel="canonical" href={`https://ambulance.saralcare.com${Astro.url.pathname}`} />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/icons/icon.svg" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Ambulances" />
    <title>{title}</title>
    <style is:global>
      :root {
        --bg: #fafaf9;
        --bg-elev: #ffffff;
        --fg: #0f172a;
        --muted: #64748b;
        --border: #e2e8f0;
        --accent: #b91c1c;
        --accent-hover: #991b1b;
        --accent-bg: #fef2f2;
        --link: #1d4ed8;
        --green: #15803d;
        --green-bg: #f0fdf4;
        --amber: #b45309;
        --amber-bg: #fffbeb;
        --grey: #6b7280;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #0b0f1a;
          --bg-elev: #131825;
          --fg: #e5e7eb;
          --muted: #94a3b8;
          --border: #1f2937;
          --accent-bg: #2a0f10;
        }
      }
      * { box-sizing: border-box; }
      html, body {
        margin: 0; padding: 0;
        background: var(--bg);
        color: var(--fg);
        font: 16px/1.55 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        overscroll-behavior-y: contain;
      }
      a { color: var(--link); text-decoration: underline; text-underline-offset: 2px; }
      a:hover { text-decoration: none; }
      .container { max-width: 880px; margin: 0 auto; padding: 0 1.1rem; }
      header.site-header {
        background: var(--bg-elev);
        border-bottom: 1px solid var(--border);
        position: sticky; top: 0; z-index: 50;
        backdrop-filter: saturate(180%) blur(8px);
      }
      header.site-header .row {
        display: flex; align-items: center; justify-content: space-between;
        padding: 0.7rem 0; gap: 0.6rem;
      }
      header.site-header h1 {
        margin: 0; font-size: 0.98rem; font-weight: 700; letter-spacing: -0.01em;
      }
      header.site-header h1 a { color: inherit; text-decoration: none; }
      header.site-header h1 a::before { content: "🚑 "; font-size: 1.1em; }
      header.site-header nav { display: flex; gap: 0.8rem; font-size: 0.88rem; }
      header.site-header nav a { color: var(--muted); text-decoration: none; padding: 0.25rem 0; }
      header.site-header nav a:hover, header.site-header nav a.active { color: var(--fg); }
      @media (max-width: 540px) {
        header.site-header nav { gap: 0.55rem; font-size: 0.82rem; }
      }
      main { padding: 1.2rem 0 4rem; }
      h2 { font-size: 1.45rem; margin: 1.6rem 0 0.6rem; letter-spacing: -0.01em; }
      h3 { font-size: 1.1rem; margin: 1.4rem 0 0.5rem; }
      footer.site-footer {
        border-top: 1px solid var(--border);
        background: var(--bg-elev);
        font-size: 0.85rem;
        color: var(--muted);
        padding: 1.5rem 0 2rem;
      }
      footer.site-footer .row { display: flex; flex-wrap: wrap; gap: 0.6rem 1.4rem; }
      footer.site-footer a { color: var(--muted); }
      footer.site-footer .legal { margin-top: 0.7rem; }
      .badge {
        display: inline-flex; align-items: center; gap: 0.25rem;
        font-size: 0.7rem; font-weight: 600;
        padding: 0.15rem 0.55rem;
        border-radius: 999px;
        color: white;
        letter-spacing: 0.02em;
        text-transform: uppercase;
      }
      .badge--verified { background: var(--green); }
      .badge--stale { background: var(--amber); color: #1a1a1a; }
      .badge--dead { background: #525252; }
      .badge--unverified { background: #94a3b8; color: #1a1a1a; }
      .badge--disputed { background: var(--accent); }
      .card {
        background: var(--bg-elev);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 0.95rem 1.05rem;
        margin: 0.55rem 0;
      }
      .small { font-size: 0.86rem; color: var(--muted); }
      button, .button {
        font: inherit;
        border: 0;
        border-radius: 10px;
        padding: 0.7rem 1rem;
        font-weight: 600;
        cursor: pointer;
        background: var(--accent);
        color: white;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.4rem;
        text-decoration: none;
        line-height: 1.2;
      }
      button:hover, .button:hover { background: var(--accent-hover); }
      button.secondary, .button.secondary {
        background: transparent;
        color: var(--fg);
        border: 1px solid var(--border);
      }
      button.secondary:hover, .button.secondary:hover { background: var(--bg); }
      input, select, textarea {
        font: inherit;
        padding: 0.65rem 0.75rem;
        border: 1px solid var(--border);
        border-radius: 10px;
        background: var(--bg-elev);
        color: var(--fg);
      }
      .hl-microcopy {
        background: var(--amber-bg);
        border: 1px solid #fde68a;
        color: #78350f;
        font-size: 0.84rem;
        padding: 0.4rem 0.7rem;
        border-radius: 8px;
      }
      details > summary { cursor: pointer; }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="container row">
        <h1><a href="/">Saralcare Ambulances</a></h1>
        <nav>
          <a href="/" class:list={[Astro.url.pathname === "/" && "active"]}>Find</a>
          <a href="/explore" class:list={[Astro.url.pathname.startsWith("/explore") && "active"]}>Explore</a>
          <a href="/for-providers" class:list={[Astro.url.pathname.startsWith("/for-providers") && "active"]}>For providers</a>
          <a href="/notice" class:list={[Astro.url.pathname.startsWith("/notice") && "active"]}>About</a>
        </nav>
      </div>
    </header>

    <main>
      <div class="container">
        <slot />
      </div>
    </main>

    <footer class="site-footer">
      <div class="container">
        <div class="row">
          <span><strong>Saralcare Ambulances</strong> — an information aggregator. <a href="/notice">How this works</a>.</span>
          <a href="/disclaimer">Disclaimer</a>
          <a href="/takedown">Corrections</a>
          <a href="/license">License</a>
          <a href="/freshness">Freshness</a>
          <a href="/changes">Recent changes</a>
          <a href="https://github.com/Ashwask/SaralcareAmbulanceservices" rel="noopener">GitHub</a>
        </div>
        <p class="legal">In any medical emergency, call <a href="tel:108"><strong>108</strong></a>. We do not operate or dispatch ambulances. Data is CC BY-NC-SA 4.0.</p>
      </div>
    </footer>

    <script is:inline>
      // Register service worker
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", () => {
          navigator.serviceWorker.register("/sw.js").catch(() => {});
        });
      }
    </script>
  </body>
</html>
